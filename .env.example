# Required
OPENCLAW_WORKSPACE=/root/.openclaw/workspace
OPENCLAW_HOME=/root/.openclaw

# GitHub activity heatmap
# Org/user whose repos to track (default: skunkceo)
GIT_ORG=your-github-org

# Optional comma-separated list of owner/repo slugs to override the default list
# GIT_REPOS=your-org/repo1,your-org/repo2

# Optional: path to local git repos for fast backfill (no rate limits, all branches)
# Set to your websites/apps directory if repos are cloned locally
# GIT_REPOS_BASE=/home/youruser/apps/websites
